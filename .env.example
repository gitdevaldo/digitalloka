# -----------------------------
# Supabase
# -----------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase PostgreSQL (session mode, port 5432)
DATABASE_URL=

# -----------------------------
# Application
# -----------------------------
APP_NAME=DigitalLoka
APP_ENV=local
APP_DEBUG=false
APP_URL=http://localhost
APP_KEY=

# Base URL for auth redirects. On Replit, falls back to REPLIT_DEV_DOMAIN automatically.
NEXT_PUBLIC_APP_URL=

# -----------------------------
# Payment Webhook
# -----------------------------
# HMAC secret for verifying incoming payment webhook signatures
PAYMENT_WEBHOOK_SECRET=

# -----------------------------
# Payments (Mayar)
# -----------------------------
# Mayar API key for creating invoices/payments
MAYAR_API_KEY=
# Mayar webhook token for verifying incoming webhook signatures (separate from API key)
MAYAR_WEBHOOK_TOKEN=
# Mayar API base URL (sandbox: https://api.mayar.club/hl/v1, production: https://api.mayar.id/hl/v1)
MAYAR_BASE_URL=https://api.mayar.club/hl/v1
# Set to "true" for sandbox mode (skips webhook signature verification)
MAYAR_SANDBOX=true

# -----------------------------
# DigitalOcean
# -----------------------------
DIGITALOCEAN_TOKEN=
DIGITALOCEAN_BASE_URL=https://api.digitalocean.com/v2
DIGITALOCEAN_CONNECT_TIMEOUT_SECONDS=3
DIGITALOCEAN_REQUEST_TIMEOUT_SECONDS=10
DIGITALOCEAN_DROPLETS_CACHE_SECONDS=20
DIGITALOCEAN_DROPLET_CACHE_SECONDS=20
DIGITALOCEAN_ACTIONS_CACHE_SECONDS=10
