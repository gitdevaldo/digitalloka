# -----------------------------
# Application
# -----------------------------
APP_NAME=DigitalLoka
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# -----------------------------
# Supabase
# -----------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase PostgreSQL
DB_CONNECTION=pgsql
DATABASE_URL=

SUPABASE_AUTH_REDIRECT_URL=http://localhost/auth/callback

# Outbound TLS verification for server -> Supabase requests.
# Production: keep true.
SUPABASE_HTTP_VERIFY_SSL=true

# Optional CA bundle path for environments with broken system CA trust.
# Production can stay empty if server CA store is healthy.
SUPABASE_HTTP_CA_BUNDLE=

# Local fallback when /auth/v1/user introspection fails.
# Production: set false.
SUPABASE_LOCAL_JWT_FALLBACK=true
SUPABASE_SESSION_USER_CACHE_SECONDS=120
SUPABASE_SESSION_NEGATIVE_CACHE_SECONDS=30

# -----------------------------
# Session / Cache / Queue
# -----------------------------
SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# -----------------------------
# Provider APIs
# -----------------------------
DIGITALOCEAN_TOKEN=
DIGITALOCEAN_BASE_URL=https://api.digitalocean.com/v2
DIGITALOCEAN_CONNECT_TIMEOUT_SECONDS=3
DIGITALOCEAN_REQUEST_TIMEOUT_SECONDS=10
DIGITALOCEAN_DROPLETS_CACHE_SECONDS=20
DIGITALOCEAN_DROPLET_CACHE_SECONDS=20
DIGITALOCEAN_ACTIONS_CACHE_SECONDS=10

# -----------------------------
# Security
# -----------------------------
ALLOWED_ORIGIN=http://localhost

# -----------------------------
# Payment
# -----------------------------
PAYMENT_WEBHOOK_SECRET=
