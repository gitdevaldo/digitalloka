# -----------------------------
# Application
# -----------------------------
APP_NAME=DigitalLoka
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# -----------------------------
# Logging
# -----------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------
# Session / Cache / Queue
# -----------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------
# Mail
# -----------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------
# Supabase
# -----------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase PostgreSQL (Laravel DB)
DB_CONNECTION=pgsql
DATABASE_URL=

SUPABASE_AUTH_REDIRECT_URL=http://localhost/auth/callback

# Outbound TLS verification for server -> Supabase requests.
# Production: keep true.
SUPABASE_HTTP_VERIFY_SSL=true

# Optional CA bundle path for environments with broken system CA trust.
# Production can stay empty if server CA store is healthy.
SUPABASE_HTTP_CA_BUNDLE=

# Local fallback when /auth/v1/user introspection fails.
# Production: set false.
SUPABASE_LOCAL_JWT_FALLBACK=true

# -----------------------------
# Provider APIs
# -----------------------------
DIGITALOCEAN_TOKEN=
DIGITALOCEAN_BASE_URL=https://api.digitalocean.com/v2

# -----------------------------
# Security
# -----------------------------
ALLOWED_ORIGIN=http://localhost
